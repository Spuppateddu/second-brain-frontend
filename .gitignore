# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.nyc_output

# next.js
/.next/
/out/
.swc/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem
*.key
*.crt

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log
lerna-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors / IDEs
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.suo
*.njsproj
*.sln
*.sw?

# claude / agent tooling
.claude/
.aider*
.cursor/

# caches
.eslintcache
.stylelintcache
.parcel-cache
.cache/
.turbo/

# tmp / system
tmp/
temp/
*.tmp
*.bak
*.orig

# storybook
storybook-static/

# playwright / cypress
/playwright-report/
/playwright/.cache/
/test-results/
/cypress/videos/
/cypress/screenshots/
